# ── GenAI / LLM keys ────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Google Gemini (default provider)
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (alternative provider — very fast inference)
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── Optional model overrides ─────────────────────────────────────────────────
# Recommended defaults (leave commented to use these automatically):
#
#   Gemini — gemini-2.5-flash-lite  (fastest/cheapest 2.5; confirmed working)
#            gemini-2.5-flash       (better reasoning, still cheap)
#
#   Groq   — llama-3.1-8b-instant   (fastest; ~750 tok/s; free tier generous)
#            llama-3.3-70b-versatile (stronger reasoning, still cheap on Groq)
#
# LLM_PROVIDER=gemini          # "gemini" | "groq"
# LLM_MODEL=gemini-2.5-flash-lite

# ── All other settings use the CHURN_ prefix ────────────────────────────────
# CHURN_EXPLANATION_ENABLED=true   # override auto-detection (true/false)
# CHURN_MLFLOW_TRACKING_URI=sqlite:///mlruns.db
